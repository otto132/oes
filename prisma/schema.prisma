// ═══════════════════════════════════════════════════════════════
// Eco-Insight Revenue OS — Prisma Schema
// ═══════════════════════════════════════════════════════════════
// Derived from src/lib/types.ts. Every table, field, relation,
// and index maps to a working product behavior.
//
// Run: npx prisma migrate dev --name init
// Seed: npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════

enum SignalType {
  ppa_announcement
  renewable_target
  job_posting
  market_entry
  conference
  registry_pain
}

enum SignalStatus {
  new_signal // "new" is reserved in some contexts
  reviewed
  converted
  dismissed
}

enum LeadStage {
  New
  Researching
  Qualified
  Converted
  Disqualified
}

enum AccountType {
  Utility
  Trader
  Retailer
  Industrial
  Developer
  Unknown
}

enum AccountStatus {
  Prospect
  Active
  Partner
  Churned
}

enum OppStage {
  Identified
  Contacted
  Discovery
  Qualified
  SolutionFit // Prisma enums can't have spaces
  Proposal
  Negotiation
  VerbalCommit
  ClosedWon
  ClosedLost
}

enum ContactRole {
  Champion
  EconomicBuyer
  TechnicalBuyer
  Influencer
  Blocker
}

enum ContactWarmth {
  Strong
  Warm
  Cold
}

enum QueueItemType {
  outreach_draft
  lead_qualification
  enrichment
  task_creation
  signal_review
}

enum QueueItemStatus {
  pending
  approved
  rejected
}

enum QueuePriority {
  High
  Normal
  Low
}

enum TaskStatus {
  Open
  InProgress
  InReview
  Done
}

enum TaskPriority {
  High
  Medium
  Low
}

enum ActivityType {
  Email
  Meeting
  Call
  Note
}

enum EmailClassification {
  positive_reply
  question
  objection
  meeting_request
  bounce
  unsubscribe
  new_domain
  auto_reply
  internal
  spam
}

enum MeetingPrepStatus {
  draft
  ready
}

enum GoalStatus {
  active
  completed
  archived
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum IntegrationTokenStatus {
  active
  error
  revoked
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

enum NotificationType {
  QUEUE_ITEM
  TASK_ASSIGNED
  MENTION
}

// ═══════════════════════════════════════════════════════════════
// TENANTS
// ═══════════════════════════════════════════════════════════════

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  plan               String   @default("free")
  settings           Json     @default("{}")
  dbConnectionString String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  users              User[]
  invitations        Invitation[]

  @@map("tenants")
}

// ═══════════════════════════════════════════════════════════════
// USERS
// ═══════════════════════════════════════════════════════════════

model User {
  id        String   @id @default(cuid())
  name      String
  initials  String   @db.VarChar(4)
  email     String   @unique
  role      Role     @default(MEMBER)
  color     String   @default("default") @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isActive             Boolean   @default(true)
  notificationPrefs    Json?
  lastLoginAt          DateTime?
  linkedinConnections  Json?     // Team member's LinkedIn connection data

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  // Relations
  ownedLeads        Lead[]             @relation("LeadOwner")
  ownedAccounts     Account[]          @relation("AccountOwner")
  ownedOpps         Opportunity[]      @relation("OppOwner")
  ownedTasks        Task[]             @relation("TaskOwner")
  assignedTasks     Task[]             @relation("TaskAssignees")
  reviewingTasks    Task[]             @relation("TaskReviewer")
  ownedGoals        Goal[]             @relation("GoalOwner")
  activities        Activity[]         @relation("ActivityAuthor")
  taskComments      TaskComment[]      @relation("CommentAuthor")
  sentInvitations    Invitation[]       @relation("SentInvitations")
  integrationTokens  IntegrationToken[]
  syncLogs           SyncLog[]
  notifications      Notification[]     @relation("notifications")
  actedNotifications Notification[]     @relation("notificationActor")

  @@index([tenantId])
  @@map("users")
}

// ═══════════════════════════════════════════════════════════════
// SIGNALS
// ═══════════════════════════════════════════════════════════════

model Signal {
  id         String       @id @default(cuid())
  type       SignalType
  title      String
  summary    String       @db.Text
  reasoning  String       @db.Text
  source     String // source name e.g. "Reuters Energy"
  sourceUrl  String? // original URL
  relevance  Int // 0–100
  confidence Float // 0.0–1.0
  agent      String       @default("Signal Hunter")
  status     SignalStatus @default(new_signal)
  detectedAt DateTime     @default(now())
  createdAt  DateTime     @default(now())

  // Extracted entities stored as JSON array of company names
  companies String[]

  // Relations
  leads Lead[] @relation("LeadSignal")

  @@index([status, detectedAt(sort: Desc)])
  @@index([type])
  @@map("signals")
}

// ═══════════════════════════════════════════════════════════════
// LEADS
// ═══════════════════════════════════════════════════════════════

model Lead {
  id      String      @id @default(cuid())
  company String
  domain  String      @default("")
  source  String // "Signal", "Manual", "Conference", etc.
  type    AccountType @default(Unknown)
  country String      @default("")
  region  String      @default("")
  stage   LeadStage   @default(New)
  pain    String      @default("") @db.Text

  // FIUAC scores stored as individual columns for queryability
  scoreFit        Int @default(50)
  scoreIntent     Int @default(50)
  scoreUrgency    Int @default(50)
  scoreAccess     Int @default(30)
  scoreCommercial Int @default(50)

  // Module fit as string array
  moduleFit String[]

  confidence Float    @default(0.5)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  signalId String?
  signal   Signal? @relation("LeadSignal", fields: [signalId], references: [id])
  ownerId  String
  owner    User    @relation("LeadOwner", fields: [ownerId], references: [id])

  @@unique([company]) // dedup by company name
  @@index([stage])
  @@index([ownerId])
  @@map("leads")
}

// ═══════════════════════════════════════════════════════════════
// ACCOUNTS
// ═══════════════════════════════════════════════════════════════

model Account {
  id          String        @id @default(cuid())
  name        String        @unique
  type        AccountType   @default(Unknown)
  country     String        @default("")
  countryCode String        @default("") @db.VarChar(2)
  region      String        @default("")
  status      AccountStatus @default(Prospect)

  // Certificate schemes as string array (GoO, ELcert, REGO, I-REC, EECS)
  schemes String[]

  // FIUAC scores
  scoreFit        Int @default(50)
  scoreIntent     Int @default(50)
  scoreUrgency    Int @default(50)
  scoreAccess     Int @default(30)
  scoreCommercial Int @default(50)

  // Cached/computed
  pipelineValue       Int      @default(0) // cached sum of open opp amounts
  lastActivityAt      DateTime @default(now())
  sentimentTrajectory Json?    // Email sentiment over time [{date, sentiment}]

  // AI Account Brief
  pain         String   @default("") @db.Text
  whyNow       String   @default("") @db.Text
  moduleFit    String[]
  competitors  String?  @db.Text
  aiConfidence Float    @default(0.5)
  aiUpdatedAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownerId       String
  owner         User          @relation("AccountOwner", fields: [ownerId], references: [id])
  contacts      Contact[]
  opportunities Opportunity[]
  activities    Activity[]
  tasks         Task[]
  goals         Goal[]

  @@index([status])
  @@index([ownerId])
  @@index([type])
  @@map("accounts")
}

// ═══════════════════════════════════════════════════════════════
// CONTACTS
// ═══════════════════════════════════════════════════════════════

model Contact {
  id          String        @id @default(cuid())
  name        String
  title       String        @default("")
  role        ContactRole   @default(Champion)
  warmth      ContactWarmth @default(Cold)
  email       String        @default("")
  phone       String?
  linkedinUrl      String?
  linkedinData     Json?    // Raw LinkedIn paste data
  personalProfile  Json?    // Claude-generated PersonalProfile
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("contacts")
}

// ═══════════════════════════════════════════════════════════════
// OPPORTUNITIES
// ═══════════════════════════════════════════════════════════════

model Opportunity {
  id          String    @id @default(cuid())
  name        String
  stage       OppStage  @default(Identified)
  amount      Int       @default(0) // euro cents in production; whole euros in seed
  probability Int       @default(5) // 0–100, auto-set from stage
  closeDate   DateTime?

  // Deal health dimensions (0–100 each)
  healthEngagement   Int @default(50)
  healthStakeholders Int @default(30)
  healthCompetitive  Int @default(50)
  healthTimeline     Int @default(70)

  // AI next action (from Pipeline Hygiene)
  nextAction     String?   @db.Text
  nextActionDate DateTime?

  // Win metadata
  winNotes         String? @db.Text
  competitorBeaten String?

  // Loss metadata
  lossReason     String?
  lossCompetitor String?
  lossNotes      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accountId       String
  account         Account           @relation(fields: [accountId], references: [id])
  ownerId         String
  owner           User              @relation("OppOwner", fields: [ownerId], references: [id])
  winLossAnalyses WinLossAnalysis[]

  @@index([accountId])
  @@index([ownerId])
  @@index([stage])
  @@map("opportunities")
}

// ═══════════════════════════════════════════════════════════════
// APPROVAL QUEUE
// ═══════════════════════════════════════════════════════════════

model QueueItem {
  id         String        @id @default(cuid())
  type       QueueItemType
  title      String
  accName    String        @default("") // denormalized for display
  accId      String? // nullable for cold outreach
  agent      String
  confidence Float         @default(0.5)

  // Confidence breakdown + sources + payload as JSON
  confidenceBreakdown Json @default("{}")
  sources             Json @default("[]") // [{name, url}]
  payload             Json @default("{}") // type-specific data

  reasoning String          @default("") @db.Text
  status    QueueItemStatus @default(pending)
  priority  QueuePriority   @default(Normal)
  createdAt DateTime        @default(now())

  // Audit trail
  reviewedById    String?
  reviewedAt      DateTime?
  rejReason       String?
  originalPayload Json? // snapshot before edit

  @@index([status, createdAt(sort: Desc)])
  @@index([type])
  @@map("queue_items")
}

// ═══════════════════════════════════════════════════════════════
// TASKS
// ═══════════════════════════════════════════════════════════════

model Task {
  id          String       @id @default(cuid())
  title       String
  status      TaskStatus   @default(Open)
  priority    TaskPriority @default(Medium)
  due         DateTime?
  source      String       @default("Manual") // "Manual", "AI Suggested", "Pipeline Hygiene Agent", etc.
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  accountId  String?
  account    Account?      @relation(fields: [accountId], references: [id])
  ownerId    String
  owner      User          @relation("TaskOwner", fields: [ownerId], references: [id])
  assignees  User[]        @relation("TaskAssignees")
  reviewerId String?
  reviewer   User?         @relation("TaskReviewer", fields: [reviewerId], references: [id])
  goalId     String?
  goal       Goal?         @relation(fields: [goalId], references: [id])
  comments   TaskComment[]

  @@index([status])
  @@index([ownerId])
  @@index([accountId])
  @@index([due])
  @@index([goalId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  text      String   @db.Text
  mentions  String[] // user IDs mentioned
  createdAt DateTime @default(now())

  // Relations
  taskId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("CommentAuthor", fields: [authorId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

// ═══════════════════════════════════════════════════════════════
// GOALS
// ═══════════════════════════════════════════════════════════════

model Goal {
  id        String     @id @default(cuid())
  title     String
  status    GoalStatus @default(active)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])
  ownerId   String
  owner     User     @relation("GoalOwner", fields: [ownerId], references: [id])
  tasks     Task[]

  @@index([ownerId])
  @@map("goals")
}

// ═══════════════════════════════════════════════════════════════
// ACTIVITIES (TIMELINE)
// ═══════════════════════════════════════════════════════════════

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  summary   String // max ~80 chars for list display
  detail    String       @default("") @db.Text
  source    String       @default("Manual") // "Outlook Sync", "Calendar Sync", "Quick Log", etc.
  noteType  String? // "insight", "objection", "competitor", etc. for Quick Log entries
  createdAt DateTime     @default(now())

  // Relations
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])
  authorId  String
  author    User     @relation("ActivityAuthor", fields: [authorId], references: [id])

  @@index([accountId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("activities")
}

// ═══════════════════════════════════════════════════════════════
// EMAILS (INBOX)
// ═══════════════════════════════════════════════════════════════

model InboxEmail {
  id         String   @id @default(cuid())
  subject    String
  fromEmail  String
  fromName   String
  preview    String   @db.Text // first ~200 chars
  receivedAt DateTime @default(now())
  isUnread   Boolean  @default(true)
  isArchived Boolean  @default(false)

  // AI classification
  classification     EmailClassification
  classificationConf Float               @default(0.5)
  classifierAgent    String              @default("Inbox Classifier")

  // Account linking
  isLinked    Boolean @default(false)
  accountId   String?
  accountName String? // denormalized
  domain      String? // sender domain for new-domain detection
  externalId  String?  @unique // Microsoft Graph message ID

  createdAt DateTime @default(now())

  @@index([isArchived, isUnread, receivedAt(sort: Desc)])
  @@index([accountId])
  @@map("inbox_emails")
}

// ═══════════════════════════════════════════════════════════════
// INTEGRATION TOKENS (OAuth)
// ═══════════════════════════════════════════════════════════════

model IntegrationToken {
  id           String   @id @default(cuid())
  provider     String
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  userEmail    String
  status       IntegrationTokenStatus @default(active)
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, userId])
  @@map("integration_tokens")
}

// ═══════════════════════════════════════════════════════════════
// MEETINGS
// ═══════════════════════════════════════════════════════════════

model Meeting {
  id             String            @id @default(cuid())
  title          String
  startTime      DateTime          // ISO datetime (was String "HH:MM")
  duration       Int               // minutes (was String "30 min")
  date           DateTime
  attendees      String[]          // display names
  attendeeEmails String[]          // email addresses for re-matching
  externalId     String?  @unique  // Microsoft Graph event ID
  prepStatus     MeetingPrepStatus @default(draft)
  createdAt      DateTime          @default(now())

  accountId   String?
  accountName String?

  @@index([date])
  @@map("meetings")
}

model SyncLog {
  id          String   @id @default(cuid())
  type        String   // "email" | "calendar"
  status      String   // "success" | "partial" | "failed"
  itemsSynced Int      @default(0)
  errors      String[]
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([userId, type, startedAt(sort: Desc)])
  @@map("sync_logs")
}

// ═══════════════════════════════════════════════════════════════
// AGENT CONFIG
// ═══════════════════════════════════════════════════════════════

model AgentConfig {
  id          String    @id @default(cuid())
  name        String    @unique // e.g. "lead_qualifier"
  displayName String // e.g. "Lead Qualifier"
  description String    @db.Text
  status      String    @default("active") // "active", "paused", "disabled"
  parameters  Json      @default("{}") // agent-specific config
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("agent_configs")
}

model AgentRun {
  id           String    @id @default(cuid())
  agentName    String
  status       String    @default("running")
  trigger      String
  itemsCreated Int       @default(0)
  itemsScanned Int       @default(0)
  itemsMatched Int       @default(0)
  errors       Json      @default("[]")
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  updatedAt    DateTime  @updatedAt

  @@index([agentName, startedAt(sort: Desc)])
  @@map("agent_runs")
}

model AgentEvent {
  id          String   @id @default(cuid())
  event       String
  payload     Json     @default("{}")
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([processed, event])
  @@map("agent_events")
}

model WinLossAnalysis {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  outcome       String      // "won" | "lost"
  analysis      Json        // Full WinLossAnalysisSchema output
  createdAt     DateTime    @default(now())

  @@index([opportunityId])
}

// ═══════════════════════════════════════════════════════════════
// INVITATIONS
// ═══════════════════════════════════════════════════════════════

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        Role             @default(MEMBER)
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(PENDING)
  invitedBy   User             @relation("SentInvitations", fields: [invitedById], references: [id])
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@index([email, status])
  @@index([token])
  @@index([tenantId])
  @@map("invitations")
}

// ═══════════════════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?            @relation("notificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type       NotificationType
  title      String
  message    String
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
