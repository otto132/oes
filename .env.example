# ── Database ──────────────────────────────────────
# Option A: Supabase (recommended for quick start)
#   1. Create project at supabase.com
#   2. Go to Settings → Database → Connection string (URI)
#   3. Paste here
#
# Option B: Neon (serverless Postgres)
#   1. Create project at neon.tech
#   2. Copy connection string from dashboard
#
# Option C: Local Postgres
#   docker run -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/eco_insight"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/eco_insight?schema=public"

# ── Microsoft Graph (Outlook + Calendar) ──────────
# 1. Go to https://entra.microsoft.com → App registrations → New
# 2. Name: "Eco-Insight Revenue OS"
# 3. Redirect URI: http://localhost:3000/api/auth/callback (Web)
# 4. API permissions → Add: Mail.Read, Calendars.Read, User.Read, offline_access
# 5. Certificates & secrets → New client secret → copy value
# 6. Copy Application (client) ID from Overview

MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/auth/callback"

# ── Cron (optional, for Vercel scheduled sync) ────
CRON_SECRET="your-random-secret-here"

# ── Authentication (NextAuth + Microsoft Entra ID) ─
# 1. Go to https://entra.microsoft.com → App registrations
# 2. Use the same app registration as above, or create a new one
# 3. Add redirect URI: http://localhost:3000/api/auth/callback/microsoft-entra-id
# 4. API permissions: openid, profile, email
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
