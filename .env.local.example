# =============================================================================
# Environment Variables for Eco-Insight
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#
#   cp .env.local.example .env.local
#
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://user:password@localhost:5432/eco_insight"

# Secret used to encrypt NextAuth.js JWTs and session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Canonical URL of the application.
# In development this is typically http://localhost:3000.
NEXTAUTH_URL="http://localhost:3000"

# Azure AD application (client) ID used for authentication.
# Found in the Azure portal under App registrations > Overview.
AZURE_AD_CLIENT_ID="00000000-0000-0000-0000-000000000000"

# Azure AD client secret for authentication.
# Created in the Azure portal under App registrations > Certificates & secrets.
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret-here"

# Azure AD tenant ID for authentication.
# Found in the Azure portal under App registrations > Overview.
AZURE_AD_TENANT_ID="00000000-0000-0000-0000-000000000000"

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

# Secret for authenticating cron job requests.
# If set, cron endpoints will require this value in the Authorization header.
# CRON_SECRET="your-cron-secret-here"

# Microsoft Graph API client ID (for Outlook integration).
# May differ from AZURE_AD_CLIENT_ID if using a separate app registration.
# MICROSOFT_CLIENT_ID="00000000-0000-0000-0000-000000000000"

# Microsoft Graph API client secret.
# MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret-here"

# OAuth redirect URI for the Microsoft integration callback.
# MICROSOFT_REDIRECT_URI="http://localhost:3000/api/integrations/microsoft/callback"
